@import '../../wxss/weui.wxss';
@import '../../wxss/common.wxss';
/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}
.bc_green{
  background-color: #FF6B6B;
}
.bc_white{
   background-color: #ffffff;
}
.new_padd{
  padding: 15rpx 30rpx;
}
.color_white{
  color: #fff;
}
.bg_white{
  color:#ffffff;
}




/* 页面样式 */
 .cont_box {
  width: 100%;
  height: 100%;
  background-color: #fff;
  padding-bottom: 120rpx;
  padding-top: 140rpx;
} 
/*订单最外层包裹  */
.weui-panel_box {
  margin-top: 10rpx;
}
/*桌台号、订单号  */
.weui_titleBox {
  height: 100rpx;
  line-height: 100rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: #000;
  border-bottom: 1px solid #e5e5e5;
}
/*去掉默认的bordr-bottom */
.weui_titleBox::after {
  border-bottom: none;
}
/*订单盒子  */
.weui_orderBox {
  height: 100rpx;
  /* line-height: 100rpx; */
  padding: 0 30rpx;
  vertical-align: sub;
  border-bottom: 1px solid #e5e5e5;
}
/*去掉默认的bordr-bottom */
.weui_orderBox::before {
  border-top: none;
}
/*合计  */
.order_sum {
  height: 100rpx;
  padding: 0 30rpx;
  line-height: 100rpx;
  color: #000;
  font-size: 32rpx;
  border-bottom: 1px solid #e5e5e5;
}
/*去掉默认的bordr-bottom */
.order_sum::after {
  border-bottom: none;
}
/*总钱数颜色  */
.order_sumMoney {
  color: #FF6B6B;
}
/*价格，份数  */
.order_price {
  font-size: 28rpx;
}
/*缝隙  */
.fenxi {
  width: 100%;
  height: 10rpx;
  background: #d9d9d9;
}

/*用餐人数  */
.guest_numInput {
  border-top: 1px #d9d9d9 solid;
  border-bottom: 1px #d9d9d9 solid;
  font-size: 28rpx;
  padding: 0 30rpx;
  height: 100rpx;
  line-height: 100rpx;
}

::-webkit-input-placeholder {
  color: #000;
}
/*选用餐人数按钮盒子  */
.guest_numBox {
  padding: 20rpx 40rpx;
  background-color: #fff;
}
/*选用餐人数按钮  */
.guest_num_choose {
  width: 80rpx;
  height: 80rpx;
  text-align: center;
  line-height: 80rpx;
  margin: 0 auto;
  background: #FF6B6B;
  border-radius: 20rpx;
  font-weight: bold;
}
/*第二行按钮  */
.weui-flex-bottom {
  margin-top: 20rpx;
}
/*输入备注  */
.beizhu_input {
  border-top: 1px #d9d9d9 solid;
  border-bottom: 1px #d9d9d9 solid;
  font-size: 28rpx;
  padding: 0 30rpx;
  height: 100rpx;
  line-height: 100rpx;
}
/*选择支付方式  */
.pay_way {
  background-color: #fff;
  padding: 0 30rpx;
  border-bottom: 1px #d9d9d9 solid;
  line-height: 100rpx;
  color: #202020;
}
/*支付方式选项  */
.pay_wayName {
  overflow: hidden;
  display: block;
}
/*支付方式名称  */
.pay_wayNameL {
  float: left;
}
/*支付状态  */
.pay_wayNameR {
  float: right;
}

/*美地餐饮套餐  */

.canyin_meidi {
  width: 100%;
  background-color: #fff;
  border-bottom: 1px #d9d9d9 solid;
}
/*美地餐饮套餐盒子  */
.taocan_yue {
  height: 65rpx;
  line-height: 65rpx;
  padding: 0 85rpx;
  font-weight: normal;
  font-size: 30rpx;
  color: #656565;
}
/* 美地餐饮套餐当前余额 */
.now_yue {
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1px #d9d9d9 solid;
}
/*当前余额、充值  */
.yue_placeholder {
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
}
/*当前余额  */
.yue_placeholderL {
  color: #FF6B6B;
}
/*充值  */
.yue_placeholderR {
  border-left: 1px #d9d9d9 solid;
  color: blue;
}

/*提交订单按钮 */
.footer_box {
  width: 100%;
  height: 100rpx;
  position: fixed;
  left: 0;
  bottom: 0rpx;
  z-index: 100;
  background-color: #fff;
}
/*总计金额、件数  */
.all_money {
  width: 90%;
  margin: 0 auto;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  background-color: #FF6B6B;
  border-radius: 20rpx;
}

/* 支付弹窗样式 */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
  }
  
  .modal-content {
    width: 90%;
    max-width: 600rpx;
    background: #fff;
    border-radius: 20rpx;
    overflow: hidden;
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #eee;
    font-size: 30rpx;
    font-weight: bold;
  }
  
  .close-btn {
    margin: 0;
    padding: 0;
    width: 40rpx;
    height: 40rpx;
    line-height: 40rpx;
    font-size: 40rpx;
    color: #999;
    background: none;
  }
  
  .coupon-section, .payment-methods {
    padding: 30rpx;
    border-bottom: 1rpx solid #eee;
  }
  
  .section-title {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20rpx;
    font-size: 28rpx;
  }
  
  .coupon-tip {
    color: #ff4f4f;
    font-size: 24rpx;
  }
  
  .coupon-selector {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx;
    background: #f5f5f5;
    border-radius: 10rpx;
  }
  
  .arrow {
    font-size: 40rpx;
    color: #999;
  }
  
  .payment-method {
    display: flex;
    align-items: center;
    padding: 20rpx 0;
  }
  
  .payment-method image {
    width: 40rpx;
    height: 40rpx;
    margin: 0 20rpx;
  }
  
  .amount-summary {
    padding: 30rpx;
  }
  
  .amount-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15rpx;
    color: #666;
  }
  
  .total-amount {
    display: flex;
    justify-content: space-between;
    margin-top: 20rpx;
    padding-top: 20rpx;
    border-top: 1rpx solid #eee;
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .total-amount .price {
    color: #ff4f4f;
  }
  
  .confirm-pay-btn {
    margin: 30rpx;
    background: linear-gradient(to right, #ff4f4f, #ff2d4b);
    color: white;
    border-radius: 50rpx;
  }

