<!-- pages/coupon/coupon.wxml -->
<view class="coupon-page">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="title">优惠券中心</view>
  </view>

  <!-- 优惠券列表 -->
  <view wx:if="{{couponList.length != 0}}" class="coupon-list">
    <block wx:for="{{couponList}}" wx:key="id">
      <view class="coupon-item {{item.status === 'used' ? 'disabled' : ''}}">
        <!-- 左侧金额区域 -->
        <view class="coupon-left">
          <text class="price">{{item.cvalue}}</text>
          <text class="unit">元</text>
          <text class="condition">满{{item.ccondition}}元可用</text>
        </view>
        
        <!-- 右侧信息区域 -->
        <view class="coupon-right">
          <text class="name">{{item.cname}}</text>
          <text class="time">有效期: {{item.startTime}}至{{item.endTime}}</text>
          
          <!-- 按钮状态 -->
          <button 
            class="btn {{item.status === 'received' ? 'received-btn' : ''}}"
            bindtap="handleGetCoupon" 
            data-id="{{item.id}}"
            disabled="{{item.status !== 'available'}}"
          >
            {{item.status === 'available' ? '立即领取' : 
              item.status === 'received' ? '已领取' : '已使用'}}
          </button>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载提示 -->
  <view wx:if="{{isLoading}}" class="loading">
    <image src="/assets/icons/loading.png" mode="aspectFit"></image>
    <text>加载中...</text>
  </view>

  <!-- 空状态提示 -->
  <view wx:if="{{couponList.length === 0 && isLoading === false }}" class="empty">
    <image src="/assets/icons/empty-coupon.png" mode="aspectFit"></image>
    <text>暂无可用优惠券</text>
  </view>
</view>