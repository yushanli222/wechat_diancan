/* 设置商家logo的样式 */
@import '../../wxss/weui.wxss';
@import '../../wxss/common.wxss';

/**app.wxss**/
.container {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 200rpx 0;
    box-sizing: border-box;
  } 
  .bc_green{
    background-color: #FF6B6B;
  }
  .bc_white{
     background-color: #ffffff;
  }
  .new_padd{
    padding: 15rpx 30rpx;
  }
  .color_white{
    color: #fff;
  }
  .bg_white{
    color:#ffffff;
  }
  
  
  /*公用  */
  
  .mb_bottom {
    margin-bottom: 12rpx;
  }
  
  .mT {
    padding: 10rpx 0rpx;
  }
  
  .bd_radius {
    border-radius: 50%;
  }
  
  /*tab  */
  
  .weui-navbar__item.weui-bar__item_on {
    color: #FF6B6B;
  }
  .tab_style {
    position: fixed;
    top: 148rpx;
    color: #333;
    background-color: #fff;
    height: 80rpx;
    line-height: 80rpx;
    padding: 0;
  }
  
  .weui-bar__item_on {
    background: #fff;
    color: #FF6B6B;
  }
  
  .padd {
    padding: 0;
  }
  
  .slider_width {
    width: 50%;
    background: #fef4d1;
  }
  
  /*内容  */
  
  .cont-wrap {
    padding-top: 190rpx;
    padding-bottom: 160rpx;
    overflow: hidden;
  }
  
  /*隐藏滚动条  */
  
  /* ::-webkit-scrollbar{
    width: 0;
    height: 0;
    color: transparent;
  } */
  
  /*左侧  */
  
  .left-cont {
    width: 23%;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    background: #f8f8f8;
    overflow: auto;
    padding-top: 230rpx;
    padding-bottom: 140rpx;
  }

  .classify {
    width: 100%;
    height: 76rpx;
    line-height: 76rpx;
    text-align: center;
    border-bottom: 1px #e8e8e8 solid;
    border-left: 6rpx #f8f8f8 solid;
    color: #666;
    font-size: 26rpx;
  }

  .active {
    background-color: #fff;
    border-left: 6rpx #FF6B6B solid;
    color: #FF6B6B;
    font-weight: 600;
  }
  
  /*右侧  */
  
  .right-cont {
    width: 77%;
    position: fixed;
    margin-left: 25%;
    top: 0rpx;
    right: 0rpx;
    bottom: 0rpx;
    background: #f8f8f8;
    overflow: auto;
    padding-top: 230rpx;
    padding-bottom: 80rpx;
  }
  
  .img_box {
    width: 140rpx;
    height: 140rpx;
    line-height: 120rpx;
    text-align: center;
    margin-left: 10rpx;
    margin-right: 30rpx;
  }
  
  .header-img {
    border-radius: 50%;
  }
  
  .cai_title {
    font-weight: 400;
    font-size: 30rpx;
    width: auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    word-wrap: normal;
    word-wrap: break-word;
    word-break: break-all;
  }
  
  .cai_desc {
    font-size: 22rpx;
    width: auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    word-wrap: normal;
    word-wrap: break-word;
    word-break: break-all;
    color: #999;
  }
  
  /*价格与数量加减器*/
  
  .price-stepper {
    padding-right: 20rpx;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
  }
  
  /*价格*/
  
  .cai_price {
    font-weight: bold;
    font-size: 32rpx;
    color: #FF6B6B;
  }
  
  /*人民币符号*/
  
  .cai_price:before {
    content: "￥";
    font-size: 14px;
  }
  
  /*加减器*/
  
  .stepper {
    flex: 1;
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    padding-right: 10rpx;
  }
  
  .value_num {
    width: 50rpx;
    text-align: center;
  }
  
  /*数量*/
  
  .value {
    font-size: 28rpx;
    margin: 0 20rpx;
    font-weight: bold;
  }
  
  /*底部  */
  
  .bottom_box {
    width: 100%;
    height: 80rpx;
    position: fixed;
    left: 0;
    bottom: 0px;
    z-index: 100;
    background-color: #fff;
  }

  .shop_cartBox {
    width: 110rpx;
    height: 110rpx;
    background-color: #FF6B6B;
    border-radius: 50%;
    position: absolute;
    top: -50rpx;
    left: 40rpx;
  }
  
  .shopCart_img {
    width: 60rpx;
    height: 60rpx;
    position: absolute;
    top: 24rpx;
    left: 24rpx;
  }
  
  .all_money {
    position: absolute;
    width: 50%;
    height: 80rpx;
    top: 0;
    left: 25%;
    line-height: 80rpx;
    text-align: center;
    font-size: 32rpx;
  }
  
  .choose_ok {
    position: absolute;
    width: 25%;
    height: 80rpx;
    top: 0;
    right: 0;
    line-height: 80rpx;
    text-align: center;
    color: #fff;
    font-size: 36rpx;
    font-weight: 500;
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  }
  
  .fontP {
    color: #FF6B6B;
    font-size: 40rpx;
  }
  
  /*弹窗遮罩层  */
  
  .modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity:0.6;
    background: #000;
     z-index: 666; 
  }
  
  /*购物车弹窗  */
  
  .cart_popup {
    width: 100%;
    height: 285px;
    background: #fff;
    position: fixed;
    z-index: 999;
    left: 0;
    bottom: -285px;
    overflow: auto;
  }
  
  .shopcart_title {
    width: 100%;
    height: 70rpx;
    line-height: 80rpx;
    text-align: center;
    position: fixed;
    left: 0;
    background-color: #ff9600;
    color: #fff;
  }
  
  /*关闭按钮  */
  
  .shopcart_close {
    position: absolute;
    left: 30rpx;
    font-size: 28rpx;
  }
  
  /*清空购物车  */
  
  .shopcart_deleteAll {
    position: absolute;
    right: 30rpx;
    font-size: 28rpx;
  }
  
  .margin_r {
    margin-right: 30rpx;
  }
  
  /*购物车列表  */
  
  .cart_cells {
    width: 100%;
    height: 98rpx;
    position: relative;
    border-bottom: 1px #dedede solid;
  }
  
  .cells_name {
    width: 40%;
    height: 50%;
    position: absolute;
    top: 0;
    left: 0;
    font-size: 14px;
    margin-left: 40rpx;
    padding-top: 10rpx;
  }
  
  .cells_price {
    width: 60%;
    height: 50%;
    position: absolute;
    top: 50rpx;
    left: 0;
    margin-left: 40rpx;
    font-size: 14px;
    padding-bottom: 10rpx;
    color: #ff9600;
  }
  
  .price-box {
    padding-right: 20rpx;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 20%;
    position: absolute;
    left: 60%;
    top: 20rpx;
  }
  
  /*删除购物车某项  */
  
  .shopcart_delete {
    position: absolute;
    right: 40rpx;
    top: 32rpx;
  }
  
  /*我的订单  */
  
  .my_menu {
    width: 100%;
    overflow: auto;
    padding-top: 140rpx;
    background: #fff;
  }
  
  .weui_titleBox {
    height: 100rpx;
    line-height: 100rpx;
    padding: 0 30rpx;
    font-size: 32rpx;
    color: #000;
  }
  
  .weui_titleBox::after {
    border-bottom: none;
  }
  
  .weui_orderBox {
    height: 100rpx;
    line-height: 100rpx;
    padding: 0 30rpx;
    vertical-align: sub;
    border-top: 1rpx solid #e5e5e5;
  }
  
  .weui_orderBox::before {
    border-top: none;
  }
  
  .bd_radius {
    border-radius: 50%;
  }
  
  .order_img {
    vertical-align: sub;
  }
  
  /*合计  */
  
  .order_sum {
    height: 100rpx;
    padding: 0 30rpx;
    line-height: 100rpx;
    color: #000;
    font-size: 32rpx;
    overflow: hidden;
    border-bottom: 1rpx solid #e5e5e5;
  }
  
  .order_sum::after {
    border-bottom: none;
  }
  
  .order_sumMoney {
    float: left;
  }
  
  .order_Money {
    color: #ff9600;
  }
  
  .order_payd {
    color: #01bf05;
    float: right;
    vertical-align: sub;
  }
  
  .paydIcon {
    vertical-align: sub;
    font-size: 48rpx;
    margin-right: 40rpx;
  }
  
  /*价格，份数  */
  
  .order_price {
    font-size: 28rpx;
  }
  
  .fenxi {
    width: 100%;
    height: 10rpx;
    background: #ddd;
  }
  /*判断是否登录  */
  .maskOne{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity:0.7;
    background: #000;
     z-index: 555; 
  }
  .w_isLoginBox{
    position: absolute;
    z-index: 888;
    width: 76%;
    height: 200px;
    left: 12%;
    top: 30%;
    background: #fff;
    border-radius: 20rpx;
    }
    /*标题  */
  .modal_title{
    width: 100%;
    line-height: 50px;
    text-align: center;
  }
  .w_isLogin{
     width: 94%; 
     margin:0  auto;
  }
  .w_input{
    border: 1px #ddd solid;
    padding:0 0 0 10rpx;
  
  }
  .w_inputCode{
    border-top: 0;
  }
  .weui-cell::before{
    border-top: none;
  }
  .getcode-btn{
    padding: 0 5px;
    background-color: #3cc51f;
    color: #fff;
  }
  /* 提交按钮 */
  .submitBtn{
    width: 50%;
    height: 40px;
    margin-top:10px;
  }

  /* 新购物车弹窗样式 */
  .cart_popup {
    width: 94%;
    height: 55vh;
    background: #fff;
    position: fixed;
    z-index: 999;
    left: 3%;
    bottom: 50rpx;
    border-radius: 32rpx 32rpx 0 0;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    overflow: hidden;
  }

  .cart_popup.show {
    transform: translateY(0);
  }

  .cart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32rpx;
    border-bottom: 1rpx solid #eee;
  }

  .cart-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }

  .cart-clear {
    font-size: 26rpx;
    color: #FF6B6B;
  }

  .cart-list {
    height: calc(60vh - 100rpx);
    padding: 0 24rpx;
  }

  .cart-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 1rpx solid #f5f5f5;
  }

  .cart-item-img {
    width: 120rpx;
    height: 120rpx;
    border-radius: 12rpx;
    margin-right: 20rpx;
    flex-shrink: 0;
  }

  .cart-item-detail {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .cart-item-name {
    font-size: 28rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 8rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cart-item-desc {
    font-size: 22rpx;
    color: #999;
    margin-bottom: 8rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cart-item-price {
    font-size: 28rpx;
    color: #FF6B6B;
  }

  .cart-item-control {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 40rpx;
    padding: 4rpx;
    flex-shrink: 0;
    margin-left: 20rpx;
  }

  .cart-minus,
  .cart-plus {
    width: 56rpx;
    height: 56rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    color: #666;
  }

  .cart-minus:active,
  .cart-plus:active {
    opacity: 0.7;
  }

  .cart-plus {
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
    color: #fff;
    border-radius: 50%;
  }

  .cart-quantity {
    min-width: 48rpx;
    text-align: center;
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
  }

  .cart-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200rpx;
    color: #999;
    font-size: 28rpx;
  }

  /* AI助手浮动按钮 */
  .ai-assistant-float {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20rpx;
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
    border-radius: 20rpx;
    margin: 20rpx;
    box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  }

  .ai-icon-large {
    width: 80rpx;
    height: 80rpx;
  }

  .ai-text-float {
    font-size: 24rpx;
    color: #fff;
    margin-top: 8rpx;
    white-space: nowrap;
    font-weight: 500;
  }

  /* AI助手弹窗遮罩层 */
  .ai-modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
  }

  /* AI助手对话框 */
  .ai-dialog {
    position: fixed;
    top: 0;
    right: 0;
    width: 85%;
    height: 100%;
    background: #fff;
    z-index: 1001;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-dialog.show {
    transform: translateX(0);
  }

  .ai-dialog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
    color: #fff;
  }

  .ai-header-left {
    display: flex;
    align-items: center;
  }

  .ai-header-icon {
    width: 50rpx;
    height: 50rpx;
    margin-right: 16rpx;
  }

  .ai-header-title {
    font-size: 32rpx;
    font-weight: 600;
  }

  .ai-close-btn {
    width: 50rpx;
    height: 50rpx;
    line-height: 50rpx;
    text-align: center;
    font-size: 48rpx;
    color: #fff;
  }

  .ai-message-list {
    flex: 1;
    padding: 30rpx;
    overflow-y: auto;
  }

  .ai-message {
    display: flex;
    margin-bottom: 30rpx;
  }

  .ai-message-bot {
    flex-direction: row;
  }

  .ai-avatar {
    width: 70rpx;
    height: 70rpx;
    border-radius: 50%;
    margin-right: 20rpx;
    flex-shrink: 0;
  }

  .ai-message-content {
    background: #f5f5f5;
    padding: 20rpx;
    border-radius: 16rpx;
    max-width: 80%;
    display: flex;
    flex-direction: column;
  }

  .ai-message-content text {
    font-size: 28rpx;
    color: #333;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* 打字机光标 */
  .typing-cursor {
    display: inline-block;
    width: 4rpx;
    height: 28rpx;
    background: #FF6B6B;
    margin-left: 4rpx;
    animation: cursorBlink 0.8s infinite;
    vertical-align: middle;
  }

  @keyframes cursorBlink {
    0%, 50% {
      opacity: 1;
    }
    51%, 100% {
      opacity: 0;
    }
  }

  /* 用户消息样式 */
  .ai-message-user {
    flex-direction: row-reverse;
  }

  .ai-message-content-user {
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
    padding: 20rpx;
    border-radius: 16rpx;
    max-width: 80%;
    display: flex;
    flex-direction: column;
  }

  .ai-message-content-user text {
    font-size: 28rpx;
    color: #fff;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* 加载动画 */
  .ai-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20rpx;
  }

  .ai-loading-dots {
    display: flex;
    align-items: center;
    margin-right: 12rpx;
  }

  .ai-loading-dots .dot {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    background: #FF6B6B;
    margin: 0 4rpx;
    animation: dotBounce 1s infinite;
  }

  .ai-loading-dots .dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .ai-loading-dots .dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  .loading-text {
    font-size: 24rpx;
    color: #999;
  }

  @keyframes dotBounce {
    0%, 80%, 100% {
      transform: scale(0.6);
      opacity: 0.5;
    }
    40% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .ai-input-area {
    display: flex;
    align-items: center;
    padding: 20rpx 30rpx;
    border-top: 1rpx solid #eee;
    background: #fff;
  }

  .ai-input {
    flex: 1;
    height: 80rpx;
    padding: 0 24rpx;
    background: #f5f5f5;
    border-radius: 40rpx;
    font-size: 28rpx;
  }

  .ai-send-btn {
    width: 120rpx;
    height: 70rpx;
    line-height: 70rpx;
    margin-left: 20rpx;
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
    color: #fff;
    font-size: 28rpx;
    border-radius: 40rpx;
    padding: 0;
  }