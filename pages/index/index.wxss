/* 基础样式 */
page {
    background: #f8f8f8;
    /* font-family: 'PingFang SC', sans-serif; */
  }
  
  /* 顶部导航 */
  .header {
    padding: 50rpx 62rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #fff;
  }
  
  .shop-name {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
  }
  
  .icon-bell {
    width: 48rpx;
    height: 48rpx;
  }
  
  /* 搜索框 */
  .search-container {
    padding: 24rpx 32rpx;
  }
  
  .search-box {
    background: #fff;
    border-radius: 48rpx;
    padding: 20rpx 32rpx;
    display: flex;
    align-items: center;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  }
  
  .icon-search {
    width: 40rpx;
    height: 40rpx;
    margin-right: 16rpx;
  }
  
  .placeholder-style {
    color: #999;
    font-size: 28rpx;
  }
  
  /* 扫码区域 */
  .scan-section {
    padding: 0 32rpx;
    margin-top: 24rpx;
  }
  
  .scan-card {
    background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
    border-radius: 24rpx;
    padding: 40rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 24rpx rgba(255,107,107,0.3);
  }
  
  .icon-scan {
    width: 64rpx;
    height: 64rpx;
    margin-right: 20rpx;
  }
  
  .scan-text {
    color: #fff;
    font-size: 34rpx;
    font-weight: 500;
  }
  
  /* 底部导航 */
  .tab-bar {
    position: fixed;
    bottom: 0;
    width: 100%;
    height: 120rpx;
    display: flex;
    justify-content: space-around;
    align-items: center;
    background: #fff;
    border-top: 1rpx solid #eee;
  }
  
  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .tab-icon {
    width: 48rpx;
    height: 48rpx;
    margin-bottom: 8rpx;
  }
  
  .tab-active text {
    color: #FF6B6B;
  }

  /* 推荐菜品区域 */
.section {
  padding: 24rpx 32rpx;
  background: #fff;
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.food-scroll {
  white-space: nowrap;
}

.food-list {
  display: inline-flex;
  gap: 24rpx;
}

.food-card {
  width: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.food-image {
  width: 280rpx;
  height: 200rpx;
  object-fit: cover;
}

.food-info {
  padding: 16rpx;
}

.food-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.food-intro {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.food-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.food-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.food-tag.new {
  background: linear-gradient(135deg, #07c160, #10b981);
}

/* index.wxss */
.login-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
  }
  
  .modal-content {
    width: 80%;
    background: #fff;
    border-radius: 24rpx;
    padding: 40rpx;
    text-align: center;
  }
  
  .login-icon {
    width: 120rpx;
    height: 120rpx;
    margin-bottom: 20rpx;
  }
  
  .modal-title {
    display: block;
    font-size: 36rpx;
    color: #333;
    font-weight: bold;
    margin-bottom: 16rpx;
  }
  
  .modal-text {
    font-size: 28rpx;
    color: #666;
    margin-bottom: 40rpx;
    display: block;
  }
  
  .login-btn {
    background: #07c160;
    color: #fff;
    border-radius: 50rpx;
    font-size: 32rpx;
    line-height: 2.6;
  }
  
  .close-btn {
    font-size: 28rpx;
    color: #999;
    margin-top: 30rpx;
    padding: 20rpx;
  }