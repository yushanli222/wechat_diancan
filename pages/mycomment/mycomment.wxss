/* pages/my-comments/my-comments.wxss */
.container {
    padding: 20rpx;
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  /* 评论列表 */
  .comment-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }
  
  .comment-item {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    position: relative;
  }
  
  /* 头部信息 */
  .comment-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20rpx;
  }
  
  .order-no {
    font-size: 28rpx;
    color: #666;
  }
  
  .comment-time {
    font-size: 24rpx;
    color: #999;
  }
  
  /* 评分 */
  .star-rating {
    margin-bottom: 20rpx;
  }
  
  .star-icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 10rpx;
  }
  
  /* 评论内容 */
  .comment-content {
    font-size: 30rpx;
    color: #333;
    line-height: 1.6;
    margin-bottom: 30rpx;
  }
  
  /* 操作栏 */
  .action-bar {
    display: flex;
    justify-content: flex-end;
  }
  
  .delete-icon {
    width: 48rpx;
    height: 48rpx;
    padding: 16rpx;
  }
  
  /* 空状态 */
  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 200rpx;
  }
  
  .empty-icon {
    width: 200rpx;
    height: 200rpx;
    margin-bottom: 30rpx;
    opacity: 0.6;
  }
  
  .empty-text {
    font-size: 28rpx;
    color: #999;
  }