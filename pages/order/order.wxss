/* 页面背景 */
page {
  background: #f8f8f8;
}

/* 顶部导航栏 */
.navbar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar .item {
  flex: 1;
  font-size: 28rpx;
  text-align: center;
  line-height: 88rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.navbar .item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.navbar .item.active::after {
  content: "";
  display: block;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 2rpx;
}

/* 空数据提示 */
.none_tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}

.none_tab::before {
  content: "";
  display: block;
  width: 200rpx;
  height: 200rpx;
  background: #eee;
  border-radius: 50%;
  margin-bottom: 30rpx;
}

/* 订单卡片 */
.cont_count {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

/* 订单头部 */
.seria {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.seriac_name {
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.seriac_name text {
  margin-left: 12rpx;
  color: #333;
  font-weight: 500;
}

.seriac_start {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
  background: rgba(255, 107, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 订单时间 */
.order-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* 菜品列表 */
.list {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.list_img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
  margin-right: 20rpx;
}

.list_info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.list_name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.list_quantity {
  font-size: 24rpx;
  color: #999;
}

.list_money {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

/* 订单底部 */
.count_eg {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cont_cen_money {
  font-size: 26rpx;
  color: #666;
}

.cont_ce_mon {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 600;
  margin-left: 8rpx;
}

/* 操作按钮区域 */
.coent_list {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: 24rpx;
  margin-top: 20rpx;
  gap: 20rpx;
}

.coent_del {
  padding: 16rpx 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  transition: all 0.3s;
}

.coent_del:active {
  background: #f5f5f5;
}

.coent_log_base {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s;
}

.coent_log_base:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.2);
}

/* 评论弹窗 */
.comment-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.comment-popup {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}

.popup-header {
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.comment-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.placeholder-style {
  color: #ccc;
}

.star-rating {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.star-icon {
  width: 50rpx;
  height: 50rpx;
  margin: 0 12rpx;
}

.action-buttons {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.cancel-btn, .submit-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  text-align: center;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

/* 支付弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 666;
}

.cart_popup {
  width: 92%;
  left: 4%;
  background: #fff;
  position: fixed;
  z-index: 999;
  bottom: 40rpx;
  border-radius: 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 50vh;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
  transform: translateY(120%);
}

.shopcart_title {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  position: relative;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 24rpx 24rpx 0 0;
}

.shopcart_close {
  position: absolute;
  right: 30rpx;
  font-size: 26rpx;
}

.cart_cells {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
  box-sizing: border-box;
}

.cart_cells.selected {
  background: rgba(255, 107, 107, 0.05);
}

.pay-icon {
  width: 52rpx;
  height: 52rpx;
  margin-right: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cells_name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.check-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  flex-shrink: 0;
}

.check-circle.checked {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-color: #FF6B6B;
}

.check-circle text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 支付按钮区域 */
.pay-btn-area {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.pay-submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #ccc;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  transition: all 0.3s;
}

.pay-submit-btn.active {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.pay-submit-btn.active:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}
