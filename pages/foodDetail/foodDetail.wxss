/* pages/foodDetail/foodDetail.wxss */

.food-detail-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 140rpx;
}

/* 顶部导航 */
.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 64rpx;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading text {
  color: #999;
  font-size: 28rpx;
}

/* 菜品内容 */
.food-content {
  padding-top: 100rpx;
}

/* 菜品图片 */
.food-image-container {
  width: 100%;
  height: 560rpx;
  background: white;
}

.food-image {
  width: 100%;
  height: 100%;
}

/* 菜品信息 */
.food-info {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
}

.food-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.food-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.food-kind {
  font-size: 24rpx;
  color: #FF6B6B;
  background: rgba(255,107,107,0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.price-value {
  font-size: 48rpx;
  color: #FF6B6B;
  font-weight: 700;
}

.storage-info {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
}

.food-intro {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 数量选择 */
.quantity-section {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-label {
  font-size: 28rpx;
  color: #333;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 8rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.qty-btn.minus:active,
.qty-btn.plus:active {
  transform: scale(0.95);
}

.qty-btn.minus {
  background: white;
}

.qty-btn.minus text {
  font-size: 36rpx;
  color: #666;
}

.qty-btn.plus {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
}

.qty-btn.plus text {
  font-size: 36rpx;
  color: white;
}

.qty-value {
  min-width: 64rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 0 16rpx;
}

/* 合计金额 */
.total-section {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.total-symbol {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.total-value {
  font-size: 44rpx;
  color: #FF6B6B;
  font-weight: 700;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: white;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.action-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  margin: 0 16rpx;
  transition: all 0.3s;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.secondary {
  border: 2rpx solid #FF6B6B;
}

.action-btn.secondary text {
  font-size: 30rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
}

.action-btn.primary text {
  font-size: 30rpx;
  color: white;
  font-weight: 500;
}
